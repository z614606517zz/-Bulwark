<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Bulwark.UI.Scifi.ViewModels"
             x:Class="Bulwark.UI.Scifi.Views.QuarantinePage"
             x:DataType="vm:QuarantineViewModel">

    <DockPanel>
        <Border DockPanel.Dock="Top" Classes="hud" Padding="16,12" Margin="0,0,0,14">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="🗃" FontSize="18" Foreground="{StaticResource StateWarnBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="隔离区" Classes="h1"/>
                    <TextBlock Text="/ QUARANTINE" Classes="label" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Foreground="{StaticResource TextDimBrush}"
                           FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Grid.Column="2" Classes="neon" Content="↻ 刷新" Click="Refresh_Click"/>
            </Grid>
        </Border>

        <Border Classes="hud" Padding="0">
            <Grid>
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="14,10"
                            BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="2*,*,*,130">
                            <TextBlock Grid.Column="0" Text="FILE" Classes="label"/>
                            <TextBlock Grid.Column="1" Text="REASON" Classes="label"/>
                            <TextBlock Grid.Column="2" Text="DATE" Classes="label"/>
                            <TextBlock Grid.Column="3" Text="OPS" Classes="label"/>
                        </Grid>
                    </Border>
                    <ListBox ItemsSource="{Binding Items}" Background="Transparent" BorderThickness="0" Padding="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:CompileBindings="False">
                                <Border Padding="14,8" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,0,0,1">
                                    <Grid ColumnDefinitions="2*,*,*,130">
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding FileName}" Foreground="{StaticResource TextHiBrush}" FontSize="12"/>
                                            <TextBlock Text="{Binding OriginalPath}" Foreground="{StaticResource TextDimBrush}" FontSize="10"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Reason}" Foreground="{StaticResource StateDangerBrush}" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding QuarantinedUtc}" Foreground="{StaticResource TextDimBrush}" FontSize="11" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4">
                                            <Button Classes="neon ok" Content="还原" Padding="6,3" FontSize="11"
                                                    Click="Restore_Click" Tag="{Binding Id}"/>
                                            <Button Classes="neon danger" Content="删除" Padding="6,3" FontSize="11"
                                                    Click="Delete_Click" Tag="{Binding Id}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

                <!-- 空状态 -->
                <StackPanel IsVisible="{Binding IsEmpty}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                    <TextBlock Text="🗃" FontSize="34" Foreground="{StaticResource TextDimBrush}" HorizontalAlignment="Center" Opacity="0.5"/>
                    <TextBlock Text="隔离区为空" Foreground="{StaticResource TextMidBrush}" FontSize="14" HorizontalAlignment="Center"/>
                    <TextBlock Text="被确认恶意并隔离的文件会出现在这里,可随时还原或永久删除" Classes="label" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </DockPanel>

</UserControl>
