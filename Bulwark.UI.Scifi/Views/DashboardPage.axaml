<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Bulwark.UI.Scifi.ViewModels"
             x:Class="Bulwark.UI.Scifi.Views.DashboardPage"
             x:DataType="vm:MainViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">

        <!-- 状态横幅 -->
        <Border Grid.Row="0" Classes="hud-glow" Padding="20,14" Margin="0,0,0,14">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="◆" FontSize="28" Foreground="{StaticResource NeonCyanBrush}"
                               VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="主动防御系统" Classes="h1"/>
                        <TextBlock Text="ACTIVE DEFENSE SYSTEM" Classes="label" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                    <Border Background="#0D2A1C" CornerRadius="12" Padding="12,5" IsVisible="{Binding IsConnected}">
                        <TextBlock Text="防护中" Foreground="{StaticResource StateOkBrush}" FontSize="12"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#2A0D14" CornerRadius="12" Padding="12,5" IsVisible="{Binding IsDisconnected}">
                        <TextBlock Text="未连接服务" Foreground="{StaticResource StateDangerBrush}" FontSize="12"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding IsConnected}">
                        <Ellipse Width="10" Height="10" Fill="{StaticResource StateOkBrush}"/>
                        <TextBlock Text="ONLINE" Foreground="{StaticResource TextDimBrush}" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding IsDisconnected}">
                        <Ellipse Width="10" Height="10" Fill="{StaticResource StateDangerBrush}"/>
                        <TextBlock Text="OFFLINE" Foreground="{StaticResource TextDimBrush}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 驱动链接状态 -->
        <Border Grid.Row="1" Classes="hud" Padding="14,10" Margin="0,0,0,10" IsVisible="{Binding IsConnected}">
            <Grid ColumnDefinitions="Auto,Auto,*">
                <Panel Grid.Column="0" Width="10" Height="10">
                    <Ellipse Width="10" Height="10" Fill="{StaticResource StateDangerBrush}"
                             IsVisible="{Binding !KernelConnected}"/>
                    <Ellipse Width="10" Height="10" Fill="{StaticResource StateOkBrush}"
                             IsVisible="{Binding KernelConnected}"/>
                </Panel>
                <TextBlock Grid.Column="1" Text="KERNEL" Classes="label" Margin="8,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding KernelStatus}" Foreground="{StaticResource NeonCyanBrush}"
                           FontFamily="{StaticResource MonoFont}" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <!-- AI Credits 月度用量条 -->
        <Border Grid.Row="2" Classes="hud" Padding="14,10" Margin="0,0,0,10" IsVisible="{Binding CreditGuardEnabled}">
            <StackPanel Spacing="6">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Column="0" Text="🤖" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="AI CREDITS" Classes="label" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding CreditUsageText}" Foreground="{StaticResource NeonCyanBrush}"
                               FontFamily="{StaticResource MonoFont}" FontSize="11" VerticalAlignment="Center"/>
                </Grid>
                <ProgressBar Minimum="0" Maximum="100" Value="{Binding CreditUsedPercent}" Height="6"
                             Foreground="{StaticResource NeonCyanBrush}" Background="#0D1A2E"/>
                <TextBlock Text="{Binding CreditBreakdownText}" Foreground="{StaticResource TextDimBrush}"
                           FontSize="10" FontFamily="{StaticResource MonoFont}" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- 统计卡片行 -->
        <Grid Grid.Row="3" ColumnDefinitions="*,*,*,*" Margin="0,0,0,14">
            <Border Grid.Column="0" Classes="hud" Padding="16,14" Margin="0,0,7,0">
                <StackPanel>
                    <TextBlock Text="ALLOWED" Classes="label"/>
                    <TextBlock Text="{Binding AllowCount}" Classes="metric"
                               Foreground="{StaticResource StateOkBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Classes="hud" Padding="16,14" Margin="7,0">
                <StackPanel>
                    <TextBlock Text="BLOCKED" Classes="label"/>
                    <TextBlock Text="{Binding BlockCount}" Classes="metric"
                               Foreground="{StaticResource StateDangerBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Classes="hud" Padding="16,14" Margin="7,0">
                <StackPanel>
                    <TextBlock Text="AI SCANS" Classes="label"/>
                    <TextBlock Text="{Binding AiScanCount}" Classes="metric"
                               Foreground="{StaticResource NeonCyanBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Classes="hud" Padding="16,14" Margin="7,0,0,0">
                <StackPanel>
                    <TextBlock Text="TOTAL" Classes="label"/>
                    <TextBlock Text="{Binding TotalEvents}" Classes="metric" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 实时日志面板 -->
        <Border Grid.Row="4" Classes="hud" Padding="0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="14,10"
                        BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                        <TextBlock Grid.Column="0" Text="●" Foreground="{StaticResource NeonCyanBrush}" FontSize="10"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="LIVE LOG" Classes="label" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <Border Grid.Column="3" Background="#0D1A2E" CornerRadius="8" Padding="8,2">
                            <TextBlock Foreground="{StaticResource TextDimBrush}" FontSize="10" FontFamily="{StaticResource MonoFont}"
                                       Text="{Binding TotalEvents, StringFormat='{}{0} events'}"/>
                        </Border>
                    </Grid>
                </Border>
                <ListBox ItemsSource="{Binding Logs}" Background="Transparent"
                         Foreground="{StaticResource TextMidBrush}"
                         FontFamily="{StaticResource MonoFont}" FontSize="12"
                         BorderThickness="0" Padding="10,6"/>
            </DockPanel>
        </Border>

        <!-- 实时日志空状态(覆盖在日志面板上) -->
        <StackPanel Grid.Row="4" IsVisible="{Binding LogsEmpty}"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
            <TextBlock Text="●" FontSize="30" Foreground="{StaticResource TextDimBrush}" HorizontalAlignment="Center" Opacity="0.4"/>
            <TextBlock Text="等待事件流…" Foreground="{StaticResource TextMidBrush}" FontSize="14" HorizontalAlignment="Center"/>
            <TextBlock Text="服务连接后,被处置的进程/文件/注册表/网络事件会实时滚动显示" Classes="label" HorizontalAlignment="Center"/>
        </StackPanel>

    </Grid>

</UserControl>
