<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Bulwark.UI.Scifi.ViewModels"
             x:Class="Bulwark.UI.Scifi.Views.ActivityLogPage"
             x:DataType="vm:ActivityLogViewModel">

    <DockPanel>
        <Border DockPanel.Dock="Top" Classes="hud" Padding="16,12" Margin="0,0,0,14">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="📡" FontSize="18" Foreground="{StaticResource NeonCyanBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="活动日志" Classes="h1"/>
                <TextBlock Text="/ ACTIVITY LOG" Classes="label" VerticalAlignment="Center" Margin="8,0,0,0"/>
                <TextBlock Text="· 放行(带风险)/ 询问 / 拦截 · 双击查看攻击时间线" Classes="label"
                           VerticalAlignment="Center" Foreground="{StaticResource NeonCyanBrush}" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

        <Border Classes="hud" Padding="8">
            <Grid>
                <ListBox x:Name="EntriesList" ItemsSource="{Binding Entries}" Background="Transparent" BorderThickness="0"
                         DoubleTapped="OnEntryDoubleTapped">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ActivityLogEntry">
                            <Border Background="#14213A" CornerRadius="6" Padding="12,10" Margin="0,0,0,6"
                                    BorderBrush="#22335577" BorderThickness="1" ToolTip.Tip="双击查看攻击时间线">
                                <Grid ColumnDefinitions="Auto,*,Auto">

                                    <Border Grid.Column="0" Width="34" Height="34" CornerRadius="6"
                                            Background="#1A2A44" VerticalAlignment="Top" Margin="0,0,12,0">
                                        <TextBlock Text="{Binding Icon}" FontSize="16"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Spacing="3">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border Background="#1A2A44" CornerRadius="3" Padding="6,1">
                                                <TextBlock Text="{Binding TypeBadge}" FontSize="11"
                                                           Foreground="{StaticResource NeonCyanBrush}" FontWeight="SemiBold"/>
                                            </Border>
                                            <TextBlock VerticalAlignment="Center" FontSize="13" TextWrapping="Wrap">
                                                <Run Text="{Binding ActorName}" Foreground="White" FontWeight="Bold"/>
                                                <Run Text=" " />
                                                <Run Text="{Binding ActionText}" Foreground="#E2ECF7"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <TextBlock Text="{Binding TargetText}" IsVisible="{Binding HasTarget}"
                                                   FontSize="12" FontFamily="{StaticResource MonoFont}"
                                                   Foreground="{StaticResource NeonCyanBrush}" TextWrapping="Wrap"/>

                                        <TextBlock Text="{Binding ActorPath}" FontSize="11"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   Foreground="{StaticResource TextDimBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Spacing="3" HorizontalAlignment="Right" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Time}" FontSize="12"
                                                   Foreground="{StaticResource TextMidBrush}" HorizontalAlignment="Right"/>
                                        <Border Background="#11243B" CornerRadius="3" Padding="6,1" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding VerdictText}" FontSize="11"
                                                       Foreground="{Binding VerdictBrush}" FontWeight="SemiBold"/>
                                        </Border>
                                        <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Right"
                                                    IsVisible="{Binding HasScore}">
                                            <TextBlock Text="风险" FontSize="10" Foreground="{StaticResource TextDimBrush}"/>
                                            <TextBlock Text="{Binding ScoreText}" FontSize="11"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       Foreground="{StaticResource StateWarnBrush}" FontWeight="Bold"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel IsVisible="{Binding IsEmpty}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                    <TextBlock Text="📡" FontSize="34" Foreground="{StaticResource TextDimBrush}" HorizontalAlignment="Center" Opacity="0.5"/>
                    <TextBlock Text="暂无活动记录" Foreground="{StaticResource TextMidBrush}" FontSize="14" HorizontalAlignment="Center"/>
                    <TextBlock Text="带风险分的放行、需询问与被拦截的事件会实时记录在此,双击可回溯攻击时间线" Classes="label" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </DockPanel>

</UserControl>
